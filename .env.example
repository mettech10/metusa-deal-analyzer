# Metalyzi Environment Variables

## Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth Hook secret — from Supabase Dashboard → Authentication → Hooks → Send Email
# Set this after wiring up the suppress-email-hook endpoint to verify requests
SUPABASE_HOOK_SECRET=your_supabase_hook_secret

## Brevo Integration (for waitlist sync and transactional emails)
# Get your API key from Brevo Dashboard → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key
# Must be a verified sender in your Brevo account
BREVO_SENDER_EMAIL=noreply@metalyzi.co.uk
# Reply-To address shown to recipients (use a real inbox to improve deliverability)
BREVO_REPLY_TO_EMAIL=hello@metalyzi.co.uk

## Apify (property scraping — actors for Rightmove, OnTheMarket, SpareRoom)
# Get your API token from https://console.apify.com/settings/integrations
# Free plan includes $5/month credit — enough for ~2,500 property scrapes
APIFY_API_TOKEN=your_apify_api_token

## Firecrawl (property scraping - runs in parallel with Apify, free tier: 500 pages/month)
# Get your API key from firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key

## Jina Reader (property scraping - free tier available, higher limits with key)
# Get your API key from jina.ai

## Backend API (Flask on Render)
# This is used for AI analysis and advanced scraping
BACKEND_API_URL=https://metusa-deal-analyzer.onrender.com

## Paddle Payments
# Client-side token — from Paddle Dashboard → Developer → Authentication
# Sandbox tokens start with "test_", production with "live_"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_a8e11e385f44173a28256226ebc
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Price IDs — from Paddle Dashboard → Catalogue → Prices
# Create one price per plan, copy the price ID (format: pri_xxxxxxxxxxxxxxxx)
NEXT_PUBLIC_PADDLE_PRICE_PAY_PER_DEAL=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRICE_UNLIMITED=pri_xxxxxxxxxxxxxxxx

# Server-side webhook secret — from Paddle Dashboard → Developer → Notifications
# Used to verify webhook signatures in production
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
